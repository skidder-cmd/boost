local function makeDraggable(topbar, frame)
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        if state.filtersOpen then
            FiltersFrame.Position = UDim2.new(frame.Position.X.Scale, frame.Position.X.Offset - FiltersFrame.Size.X.Offset - 10, frame.Position.Y.Scale, frame.Position.Y.Offset)
        end
        if state.blacklistOpen then
            BlacklistFrame.Position = UDim2.new(frame.Position.X.Scale, frame.Position.X.Offset + MainFrame.Size.X.Offset + 10, frame.Position.Y.Scale, frame.Position.Y.Offset)
        end
        if state.autoForceOpen then
            AutoForceFrame.Position = UDim2.new(frame.Position.X.Scale, frame.Position.X.Offset + MainFrame.Size.X.Offset + 10, frame.Position.Y.Scale, frame.Position.Y.Offset)
        end
    end
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end
