local function createLog(data)
    pcall(function()
        local rawMoney = cleanMoney(data.money)
        local moneyVal = getNormalizedMoney(rawMoney)
        local petName  = data.name or "Unknown"

        if moneyVal < state.minMoney then return end
        if state.blacklist[petName]   then return end

        local tierColor = COLORS.Tier1
        if     moneyVal >= 100 then tierColor = COLORS.Tier4
        elseif moneyVal >= 50  then tierColor = COLORS.Tier3
        elseif moneyVal >= 15  then tierColor = COLORS.Tier2 end

        local gradientSeq = {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(18, 12, 30)),
            ColorSequenceKeypoint.new(1, tierColor)
        }

        local shouldForce = false
        if state.autoForceList[petName] then shouldForce = true end
        if state.autoForceJoin and moneyVal >= state.minForceMoney then shouldForce = true end

        if shouldForce then
            ultraCheckjobid(data.jobid)
            state.forceStartTime = os.clock()
        end

        local row = Instance.new("Frame")
        row.Name             = data.jobid
        row.Size             = UDim2.new(1, 0, 0, 36)
        row.BackgroundColor3 = Color3.new(1, 1, 1)
        row.BorderSizePixel  = 0
        row.ClipsDescendants = true
        row.Parent           = LogScroll
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

        local rowGrad = Instance.new("UIGradient")
        rowGrad.Color    = ColorSequence.new(gradientSeq)
        rowGrad.Rotation = 0
        rowGrad.Parent   = row

        local shimmer = Instance.new("Frame")
        shimmer.Name                = "Shimmer"
        shimmer.Size                = UDim2.new(0, 40, 2, 0)
        shimmer.Position            = UDim2.new(-0.2, 0, -0.5, 0)
        shimmer.BackgroundColor3    = Color3.fromRGB(255, 255, 255)
        shimmer.BackgroundTransparency = 1
        shimmer.Rotation            = 25
        shimmer.ZIndex              = 2
        shimmer.Parent              = row
        local shimmerGrad = Instance.new("UIGradient")
